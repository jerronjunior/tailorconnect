rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users: readable by any signed-in user (public profile), writable only by owner.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role; // role is immutable
      allow delete: if false;
    }

    // Tailor business profiles: public read, owner write.
    match /tailors/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && (
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tailor' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tailor'
      );
      allow update: if isOwner(uid) && userRole() == 'tailor';
      allow delete: if false;
    }

    // Measurement profiles: private to the customer.
    match /users/{uid}/measurements/{profileId} {
      allow read, write: if isOwner(uid);
    }

    // Orders: visible only to the customer and tailor on the order.
    match /orders/{orderId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.customerId
            || request.auth.uid == resource.data.tailorId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.customerId;
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.customerId
            || request.auth.uid == resource.data.tailorId);
      allow delete: if false;
    }

    // Chat threads and messages: participants only.
    match /chats/{chatId} {
      allow read, write: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if false;
      }
    }

    // Reviews: public read; only the reviewing customer may create.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.customerId;
      allow update, delete: if isOwner(resource.data.customerId);
    }

    // Notifications: private to the recipient.
    match /users/{uid}/notifications/{notifId} {
      allow read, update, delete: if isOwner(uid);
      allow create: if isSignedIn();
    }
  }
}
